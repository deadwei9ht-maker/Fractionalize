
rules_version = '2';
 
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /fractionalizedNfts/{nftId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && request.query.where.size() == 1 && request.query.where[0].field == "userId" && request.query.where[0].op == "==" && request.query.where[0].value == request.auth.uid;
    }

    match /aiNfts/{aiNftId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null;
    }

    match /realEstate/{propertyId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && request.query.where.size() == 1 && request.query.where[0].field == "userId" && request.query.where[0].op == "==" && request.query.where[0].value == request.auth.uid;
    }
  }
}
