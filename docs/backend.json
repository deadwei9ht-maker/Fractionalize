{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public profile.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        }
      },
      "required": ["displayName", "email"]
    },
    "FractionalizedNft": {
      "title": "Fractionalized NFT",
      "description": "Represents an NFT that has been fractionalized.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who fractionalized the NFT."
        },
        "nftContract": {
          "type": "string",
          "description": "The contract address of the NFT."
        },
        "tokenId": {
          "type": "string",
          "description": "The token ID of the NFT."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the NFT was fractionalized."
        }
      },
      "required": ["userId", "nftContract", "tokenId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "Stores public information about a user."
    },
    "/fractionalizedNfts/{nftId}": {
      "schema": {
        "$ref": "#/backend/entities/FractionalizedNft"
      },
      "description": "Stores information about fractionalized NFTs."
    }
  }
}
